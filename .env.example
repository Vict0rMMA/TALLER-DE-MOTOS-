# === Servidor ===
NODE_ENV=development
PORT=4000

# === Base de datos ===
DATABASE_URL="postgresql://USER:PASSWORD@HOST:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/postgres?sslmode=require"

# === Auth / admin inicial ===
JWT_SECRET="change-me-use-openssl-rand-hex-32"
ADMIN_EMAIL="admin@example.com"
ADMIN_PASSWORD="ChangeMe123!"

# === IA (opcional) ===
GROQ_API_KEY=""
GEMINI_API_KEY=""

# === URLs ===
APP_URL="http://localhost:3000"
PUBLIC_APP_URL="https://taller-mts.vercel.app"
EXTRA_ORIGINS="https://taller-mts.vercel.app"

# === Supabase Storage (fotos) — service_role JWT eyJ… ===
SUPABASE_URL=""
SUPABASE_SERVICE_KEY=""

# === Upstash Redis (rate-limit + OTP del portal) ===
# Sin esto cae a memoria (solo dev). En Vercel es necesario para que el login
# del cliente por OTP funcione bien entre instancias serverless.
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# === Vercel Cron (recordatorios) ===
# Opcional pero recomendado: si lo defines, el endpoint /api/v1/cron/reminders
# exige el header que Vercel Cron envía. Pon el MISMO valor en Vercel.
CRON_SECRET=""

# === WhatsApp ===
# Canal a usar: web (whatsapp-web.js) | twilio | meta. Por defecto: web.
WHATSAPP_PROVIDER=web

# --- web (whatsapp-web.js): solo local o VPS, NO funciona en Vercel ---
ENABLE_WHATSAPP=true
WHATSAPP_LAZY_START=true
# CHROME_PATH="C:\Program Files\Google\Chrome\Application\chrome.exe"
# CHROME_PATH=/usr/bin/chromium-browser

# --- twilio (BSP oficial, sí funciona en Vercel) ---
# Empezar con el Sandbox: from = número del sandbox (ej. +14155238886).
# Luego producción: from = número dedicado del taller.
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_WHATSAPP_FROM=""

# --- meta (Cloud API oficial) ---
WHATSAPP_PHONE_NUMBER_ID=""
WHATSAPP_ACCESS_TOKEN=""
