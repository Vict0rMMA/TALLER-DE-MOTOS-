NODE_ENV=development
DATABASE_URL="postgresql://USER:PASSWORD@HOST:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/postgres?sslmode=require"
JWT_SECRET="change-me-use-openssl-rand-hex-32"
PORT=4000
ADMIN_EMAIL="admin@example.com"
ADMIN_PASSWORD="ChangeMe123!"

GROQ_API_KEY=""
GEMINI_API_KEY=""
APP_URL="http://localhost:3000"
# Enlaces a clientes (recibos WhatsApp) — siempre URL pública
PUBLIC_APP_URL="https://taller-mts.vercel.app"
EXTRA_ORIGINS="https://taller-mts.vercel.app"

# Supabase Storage (opcional — alternativa a Cloudinary)
SUPABASE_URL=""
SUPABASE_SERVICE_KEY=""

# Cloudinary (fotos: servicios, logo taller) — https://cloudinary.com
# Guía: docs/CLOUDINARY.md
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""
CLOUDINARY_UPLOAD_PRESET="motobrain_services"

# Bot WhatsApp (solo API en proceso largo: local o VPS; no Vercel)
ENABLE_WHATSAPP=true
# Windows: ruta a Chrome si no se detecta solo
# CHROME_PATH="C:\\Program Files\\Google\\Chrome\\Application\\chrome.exe"
