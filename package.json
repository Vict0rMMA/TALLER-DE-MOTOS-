{
  "name": "motobrain-api",
  "version": "1.0.0",
  "description": "API de gestión de talleres de motos — Express + TypeScript + Prisma + PostgreSQL",
  "main": "dist/index.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "build": "prisma generate && tsc",
    "start": "node dist/index.js",
    "postinstall": "prisma generate",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:deploy": "prisma migrate deploy",
    "prisma:seed": "ts-node-dev --transpile-only prisma/seed.ts",
    "prisma:studio": "prisma studio",
    "check:env": "node scripts/verify-supabase-env.js",
    "setup:storage": "node scripts/setup-supabase-storage.mjs",
    "vps:install": "bash scripts/vps-install-service.sh"
  },
  "keywords": [
    "nodejs",
    "express",
    "prisma",
    "postgresql",
    "jwt"
  ],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@supabase/supabase-js": "^2.105.4",
    "@types/nodemailer": "^8.0.0",
    "@types/pdfkit": "^0.17.6",
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.38.0",
    "bcryptjs": "^3.0.3",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "exceljs": "^4.4.0",
    "express": "^5.2.1",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "multer": "^1.4.5-lts.1",
    "nodemailer": "^8.0.10",
    "pdfkit": "^0.18.0",
    "pg": "^8.20.0",
    "qrcode": "^1.5.4",
    "reflect-metadata": "^0.2.2",
    "sharp": "^0.34.5",
    "ts-node-dev": "^2.0.0",
    "twilio": "^6.0.2",
    "typescript": "^6.0.3",
    "whatsapp-web.js": "^1.34.7",
    "zod": "^4.4.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^2.1.0",
    "@types/node": "^25.8.0",
    "@types/pg": "^8.20.0",
    "@types/qrcode": "^1.5.6",
    "nodemon": "^3.1.14",
    "prisma": "^7.8.0"
  }
}
